# R
Graph3 <- ggplot(data = mpg, aes(x = displ, y = hwy)) +
geom_point(aes(color=class, shape=drv, ))
Graph3 + labs(title="Engine Displacement vs. Highway MPG", x="Engine Size (Liters)", y="Highway MPG") + facet_wrap( ~ cyl) + + geom_smooth(method = lm)
