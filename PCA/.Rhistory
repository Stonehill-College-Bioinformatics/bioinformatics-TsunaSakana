x <- rnorm(30, mean=98.7, sd=0.5)
y <- rnorm(30, mean=98.6, sd=0.5)
t.test(x-y,mu = 0, alternative = "greater")
x <- rnorm(30, mean=98.7, sd=0.5)
y <- rnorm(30, mean=98.6, sd=0.4)
t.test(x, y, alternative = "greater", mu = 0, paired = FALSE, var.equal = FALSE)
