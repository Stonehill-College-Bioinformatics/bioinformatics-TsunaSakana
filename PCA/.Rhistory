library(BSDA)
x <- rnorm(30, mean=0.5, sd=1)
z.test(x,sigma.x=1)
x <- rnorm(30, mean=99.9, sd=0.5)
t.test(x,mu = 98.6, alternative = "greater")
x <- rnorm(30, mean=99.9, sd=0.5)
t.test(x,mu = 98.6, alternative = "greater")
x <- rnorm(30, mean=99.9, sd=0.5)
t.test(x,mu = 98.6, alternative = "greater")
x <- rnorm(30, mean=99.9, sd=0.5)
